[Unit]
Description=NestTube – Curated YouTube TV
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/nesttube
EnvironmentFile=/home/pi/nesttube/.env
ExecStart=/home/pi/nesttube/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target

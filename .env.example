# Copy this file to .env and fill in your values.

# Obtain from https://console.cloud.google.com — enable YouTube Data API v3
YOUTUBE_API_KEY=

# Generated on first launch via the Admin Panel setup screen.
# You can also generate manually:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'your_passcode', bcrypt.gensalt()).decode())"
ADMIN_PASSCODE_HASH=

# Random string used to sign NiceGUI session cookies. Change before first boot.
SECRET_KEY=

# Port to listen on (default 8000)
PORT=8000
